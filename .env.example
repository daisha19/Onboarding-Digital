# Copie este arquivo para .env e troque os valores marcados como change-me.
# Nunca coloque senhas ou secrets reais neste arquivo, pois ele pode ser versionado.

# Configuracoes do PostgreSQL usado pelo docker-compose.
POSTGRES_DB=onboarding_db
POSTGRES_USER=onboarding_user

# Troque por uma senha local forte no .env.
POSTGRES_PASSWORD=change-me

# Dentro do docker-compose, o host do banco deve ser o nome do servico: db.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Troque a senha da URL para o mesmo valor definido em POSTGRES_PASSWORD.
DATABASE_URL=postgresql://onboarding_user:change-me@db:5432/onboarding_db

# Troque por uma chave longa e aleatoria no .env.
SECRET_KEY=change-me

# Tempo de expiracao do token JWT, em minutos.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Tamanho maximo de upload, em MB.
UPLOAD_MAX_SIZE_MB=10

# Origens autorizadas para o frontend consumir a API, separadas por virgula.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed local para testes: use estes valores como exemplo ao criar o primeiro RH.
# O script nao le estes campos automaticamente; eles servem como referencia local.
# INITIAL_RH_EMAIL=rh@example.com
# INITIAL_RH_PASSWORD=change-me
# INITIAL_RH_MATRICULA=1001
# INITIAL_RH_CARGO=Analista de RH
